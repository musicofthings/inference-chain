# Normalize line endings: store everything as LF in the repo, regardless of
# the OS it was authored on. Resolves the CRLF/LF churn that made every file
# on a Windows checkout show as "modified".
* text=auto eol=lf

# Keep shell scripts LF even if checked out on Windows.
*.sh text eol=lf

# Binary assets — never apply EOL conversion.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.db   binary
*.sqlite binary
